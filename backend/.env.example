# Supabase Postgres 連線字串（Supabase Dashboard -> Project Settings -> Database -> Connection string -> URI，
# 記得把 postgresql:// 換成 postgresql+asyncpg://）
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# 用來簽發 JWT 的密鑰，正式環境請換成隨機長字串
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 允許的前端網址
FRONTEND_ORIGIN=http://localhost:5173
