# Supabase Postgres 連線字串。
# 注意：db.<ref>.supabase.co 這個直連網址目前只有 IPv6，很多網路環境（含台灣多數 ISP）連不上，
# 會出現 "getaddrinfo failed"。請改用 Connection Pooler（Supavisor）網址，它有 IPv4：
# Supabase Dashboard -> Project Settings -> Database -> Connection string -> Session pooler
# 記得把 postgresql:// 換成 postgresql+asyncpg://，密碼中若有 @ 等特殊字元要做 URL encode（@ -> %40）。
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# 用來簽發 JWT 的密鑰，正式環境請換成隨機長字串
JWT_SECRET_KEY=change-me-to-a-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS 允許的前端網址
FRONTEND_ORIGIN=http://localhost:5173

# Supabase Project URL 與 service_role key（Project Settings -> API），用來讓後端上傳商品圖片到 Supabase Storage。
# service_role key 權限等同管理員，絕對不能外洩到前端或 git，只在後端使用。
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# 給 Vercel Cron 呼叫生日優惠券排程端點驗證用的密鑰
CRON_SECRET=change-me

# LINE Pay 串接密鑰（LINE Pay Merchant Center -> 你的 Channel -> Payment Integration 頁面可以看到）
# 測試階段用 sandbox 的 Channel ID/Secret，正式上線後換成正式環境的 Channel 並把 LINE_PAY_ENV 改成 production
LINE_PAY_CHANNEL_ID=YOUR_LINE_PAY_CHANNEL_ID
LINE_PAY_CHANNEL_SECRET=YOUR_LINE_PAY_CHANNEL_SECRET
LINE_PAY_ENV=sandbox

# 後端自己的對外網址，組成 LINE Pay 付款完成後導回的 confirmUrl / cancelUrl 用
BACKEND_BASE_URL=http://localhost:8000
